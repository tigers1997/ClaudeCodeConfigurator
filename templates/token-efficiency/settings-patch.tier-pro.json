{
  "env": {
    "CLAUDE_BASH_MAX_LINES": "80"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/truncate-bash-output.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
